{
  "name": "@mlc/cli",
  "version": "0.1.0",
  "bin": {
    "mlc": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "targets": [
      "node18-macos-arm64",
      "node18-linux-x64",
      "node18-win-x64"
    ],
    "outputPath": "../../bin"
  },
  "dependencies": {
    "@mlc/core": "*",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "inquirer": "^9.2.0",
    "js-yaml": "^4.1.1",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/js-yaml": "^4.0.9"
  }
}
